---
interface Card {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

interface Props {
  sectionId: string;
  heading: string;
  subheading: string;
  cards: Card[];
}

const { sectionId, heading, subheading, cards } = Astro.props;
---

<section class="quals" id={sectionId}>
  <div class="container">
    <h2 class="section-heading">{heading}</h2>
    <p class="section-subheading">{subheading}</p>
    <div class="quals__grid">
      {cards.map((card) => (
        card.href ? (
          <a href={card.href} class="quals__card quals__card--link">
            <span class="quals__icon" aria-hidden="true">{card.icon}</span>
            <h3 class="quals__title">{card.title}</h3>
            <p class="quals__desc">{card.description}</p>
          </a>
        ) : (
          <div class="quals__card">
            <span class="quals__icon" aria-hidden="true">{card.icon}</span>
            <h3 class="quals__title">{card.title}</h3>
            <p class="quals__desc">{card.description}</p>
          </div>
        )
      ))}
    </div>
  </div>
</section>

<style>
  .quals { background-color: var(--color-bg-light); padding: 5rem 0; }
  .quals__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .quals__card {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: 0.875rem;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: box-shadow 0.2s, transform 0.2s;
    color: inherit;
    text-decoration: none;
  }
  .quals__card:hover { box-shadow: 0 6px 24px rgba(49,46,129,0.12); transform: translateY(-2px); }
  .quals__card--link:hover .quals__title { color: var(--color-accent-dark); }
  .quals__icon { font-size: 2rem; line-height: 1; margin-bottom: 0.25rem; }
  .quals__title { font-size: 1.0625rem; font-weight: 700; color: var(--color-primary); line-height: 1.3; }
  .quals__desc { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.65; }
  @media (max-width: 900px) { .quals__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .quals { padding: 3rem 0; } .quals__grid { grid-template-columns: 1fr; } }
</style>
