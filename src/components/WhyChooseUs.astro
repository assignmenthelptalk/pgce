---
interface Item {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  heading: string;
  items: Item[];
}

const { heading, items } = Astro.props;
---

<section class="why">
  <div class="container">
    <h2 class="section-heading">{heading}</h2>
    <div class="why__grid">
      {items.map((item) => (
        <div class="why__item">
          <div class="why__icon-wrap" aria-hidden="true">
            <span class="why__icon">{item.icon}</span>
          </div>
          <div class="why__body">
            <h3 class="why__title">{item.title}</h3>
            <p class="why__desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why {
    background-color: var(--color-bg-light);
    padding: 5rem 0;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .why__item {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: 0.875rem;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .why__item:hover {
    box-shadow: 0 6px 24px rgba(27, 43, 75, 0.08);
    transform: translateY(-2px);
  }

  .why__icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background-color: var(--color-accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .why__icon {
    font-size: 1.375rem;
    line-height: 1;
  }

  .why__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .why__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .why {
      padding: 3rem 0;
    }

    .why__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
