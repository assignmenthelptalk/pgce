---
interface Props {
  sectionId: string;
  heading: string;
  paragraphs: string[];
  highlights: string[];
  imagePlaceholderAlt: string;
}

const { sectionId, heading, paragraphs, highlights, imagePlaceholderAlt } = Astro.props;
---

<section class="about" id={sectionId}>
  <div class="container">
    <div class="about__grid">
      <div class="about__text">
        <h2 class="about__heading">{heading}</h2>
        <div class="about__paras">
          {paragraphs.map((p) => (
            <p class="about__para">{p}</p>
          ))}
        </div>
        <ul class="about__highlights" aria-label="Key highlights">
          {highlights.map((item) => (
            <li class="about__highlight-item">{item}</li>
          ))}
        </ul>
      </div>
      <div class="about__visual">
        <div class="about__placeholder" role="img" aria-label={imagePlaceholderAlt}>
          <div class="about__placeholder-inner">
            <span class="about__placeholder-icon">🏆</span>
            <strong>Trusted by 5,000+ students</strong>
            <span>ATHE CX Specialists since 2013</span>
          </div>
          <div class="about__stat-badges">
            <div class="about__stat-badge">
              <strong>98%</strong>
              <span>Pass Rate</span>
            </div>
            <div class="about__stat-badge">
              <strong>4.9★</strong>
              <span>Avg. Rating</span>
            </div>
            <div class="about__stat-badge">
              <strong>24/7</strong>
              <span>Support</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: var(--color-bg-white);
    padding: 5rem 0;
  }

  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.25;
    margin-bottom: 1.5rem;
    letter-spacing: -0.015em;
  }

  .about__paras {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .about__para {
    color: var(--color-text-muted);
    line-height: 1.75;
    font-size: 1rem;
  }

  .about__highlights {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .about__highlight-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-base);
    line-height: 1.5;
  }

  .about__highlight-item::before {
    content: '✓';
    flex-shrink: 0;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
    margin-top: 0.05em;
  }

  /* Visual column */
  .about__placeholder {
    background-color: var(--color-bg-light);
    border-radius: 1.25rem;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    min-height: 340px;
    justify-content: center;
    border: 1px solid var(--color-border-light);
  }

  .about__placeholder-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .about__placeholder-icon {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .about__placeholder-inner strong {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .about__placeholder-inner span {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .about__stat-badges {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .about__stat-badge {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: 0.75rem;
    padding: 0.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .about__stat-badge strong {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .about__stat-badge span {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about__visual {
      order: -1;
    }

    .about__placeholder {
      min-height: auto;
    }
  }
</style>
