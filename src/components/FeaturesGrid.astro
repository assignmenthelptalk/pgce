---
interface Card {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  heading: string;
  cards: Card[];
}

const { heading, cards } = Astro.props;
---

<section class="features">
  <div class="container">
    <h2 class="section-heading">{heading}</h2>
    <div class="features__grid">
      {cards.map((card) => (
        <div class="features__card">
          <span class="features__icon" aria-hidden="true">{card.icon}</span>
          <h3 class="features__title">{card.title}</h3>
          <p class="features__desc">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background-color: var(--color-bg-white);
    padding: 5rem 0;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .features__card {
    background-color: var(--color-bg-light);
    border: 1px solid var(--color-border-light);
    border-radius: 0.875rem;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .features__card:hover {
    box-shadow: 0 6px 24px rgba(27, 43, 75, 0.08);
    transform: translateY(-2px);
  }

  .features__icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .features__title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
  }

  .features__desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .features {
      padding: 3rem 0;
    }

    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
